{
  "packages": [
    "npm:pi-powerline-footer",
    "npm:@juicesharp/rpiv-ask-user-question",
    "git:github.com/hiennguyen9874/pi-edit",
    "git:github.com/hiennguyen9874/pi-shake",
    "git:github.com/hiennguyen9874/pi-grep-glob",
    "-git:github.com/hiennguyen9874/pi-ast-grep",
    "-git:github.com/hiennguyen9874/pi-hashline-edit",
    "-npm:@ff-labs/pi-fff",
    "-npm:pi-context-prune",
    "-git:github.com/MasuRii/pi-rtk-optimizer",
    "-npm:pi-mcp-adapter",
    "-npm:pi-prompt-template-model",
    "-npm:pi-subagents",
    "-git:github.com/hiennguyen9874/pi-goal",
    "-git:github.com/davebcn87/pi-autoresearch",
    "-npm:pi-intercom",
    "-npm:pi-cache-graph",
    "-npm:pi-tool-display",
    "-npm:context-mode",
    "-npm:pi-btw",
    "-npm:pi-context"
  ],
  "extensions": [
    "./extensions/command-history/index.ts",
    "./extensions/permission-gate.ts",
    "-./extensions/confirm-destructive.ts",
    "-./extensions/dirty-repo-guard.ts",
    "./extensions/inline-bash.ts",
    "./extensions/profile/index.ts",
    "./extensions/pi-documentation.ts",
    "./extensions/project-context-rewriter.ts",
    "./extensions/skills-instructions-rewriter.ts",
    "./extensions/prompt-skills.ts",
    "./extensions/save-last-response.ts",
    "./extensions/dump-system-prompt.ts",
    "-./extensions/visual-explainer.ts"
  ],
  "extensionState": {
    "piDocumentationEnabled": false,
    "projectContextRewriterDisableProjectContext": false,
    "skillsInstructionsRewriterEnabled": true,
    "skillsInstructionsRewriterDisableSkills": false,
    "systemPromptAppenderEnabled": true,
    "systemPromptAppenderPromptPath": "system-prompt.md",
    "skillsInstructionsRewriterDisabledSkillFilters": [
      "context-mode",
      "ctx-doctor",
      "ctx-insight",
      "ctx-purge",
      "ctx-stats",
      "ctx-upgrade",
      "find-skills"
    ]
  },
  "piEdit": {
    "fuzzyMatch": true,
    "fuzzyThreshold": 0.95
  },
  "subagents": {
    "agentOverrides": {
      "scout": {
        "disabled": false,
        "model": "openai-codex/gpt-5.4-mini"
      },
      "planner": {
        "disabled": true
      },
      "worker": {
        "disabled": true
      },
      "reviewer": {
        "disabled": true
      },
      "context-builder": {
        "disabled": true
      },
      "researcher": {
        "disabled": true
      },
      "delegate": {
        "disabled": true
      },
      "oracle": {
        "disabled": false,
        "model": "openai-codex/gpt-5.5"
      }
    }
  }
}
